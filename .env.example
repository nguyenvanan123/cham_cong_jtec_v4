# Sao chép file này thành .env.local khi phát triển cục bộ
# KHÔNG commit file .env thật lên Git

# ── Supabase ──────────────────────────────────────────────────────────────────
# Lấy từ: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Lấy từ: Cloudinary Dashboard > Settings > Upload > Upload presets
# VITE_CLOUDINARY_CLOUD  = Cloud name (ví dụ: dtvqq32lt)
# VITE_CLOUDINARY_PRESET = Tên unsigned upload preset (ví dụ: chamcong_unsigned)
VITE_CLOUDINARY_CLOUD=your_cloud_name
VITE_CLOUDINARY_PRESET=your_unsigned_preset_name

# ── Server (chỉ dùng khi chạy local) ─────────────────────────────────────────
PORT=5000
BASE_PATH=/
