# Sao chép file này thành .env rồi điền thông tin thật vào
# cp .env.example .env

# Lấy từ Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Lấy từ Supabase Dashboard → Project Settings → API → anon / public
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Giữ nguyên 2 dòng này
PORT=5000
BASE_PATH=/

# Chỉ cần khi deploy Netlify — trỏ đến Railway API server
# VITE_API_URL=https://your-railway-app.railway.app
