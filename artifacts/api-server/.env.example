# Sao chép file này thành .env rồi điền thông tin thật vào
# cp .env.example .env

# Port API server chạy (giữ nguyên 8080)
PORT=8080

# Lấy từ Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Lấy từ Supabase Dashboard → Project Settings → API → service_role (secret)
# KHÔNG chia sẻ key này với ai — chỉ dùng ở server, không commit lên git
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
